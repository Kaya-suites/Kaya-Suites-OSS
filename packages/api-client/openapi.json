{
  "openapi": "3.1.0",
  "info": {
    "title": "Kaya Suites API",
    "description": "OSS self-hosted Kaya Suites backend",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["ops"],
        "operationId": "health",
        "summary": "Health check",
        "description": "Returns {\"status\":\"ok\"} when the service is running.",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  },
                  "required": ["status"]
                },
                "example": {
                  "status": "ok"
                }
              }
            }
          }
        }
      }
    }
  }
}
