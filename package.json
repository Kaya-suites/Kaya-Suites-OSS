{
  "name": "kaya-suites",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "generate": "pnpm --filter @kaya/api-client generate"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "handlebars": ">=4.7.9",
      "postcss": ">=8.5.10",
      "tar": ">=7.5.8"
    }
  }
}
